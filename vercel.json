{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["public/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "crons": [
    { "path": "/api/cron/sheet-sync", "schedule": "0 0 * * *" }
  ]
}
