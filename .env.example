# ── Supabase (get these from: Supabase Dashboard → Settings → Database) ──────
# Use the "Connection string" → "URI" tab, looks like:
# postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT secret (make up any long random string) ───────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_here

# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=your_claude_key_here   # optional fallback

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
